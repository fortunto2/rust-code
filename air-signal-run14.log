import { DataModule } from '../../types';

export const earthquakeModule: DataModule = {
  id: "earthquake",
  name: "Earthquake Activity",
  weight: 0.08,
  icon: "seismic-activity", // Placeholder icon
  enabled: true,
  async fetch(lat, lon) {
    const url = `https://earthquake.usgs.gov/fdsnws/event/1/query?format=geojson&latitude=${lat}&longitude=${lon}&maxradiuskm=500&limit=1`;
    const response = await fetch(url);
    return await response.json();
  },
  normalize(data: { features: Array<{ properties: { mag: number, place: string } }> }): SubScore {
    if (!data.features || data.features.length === 0) {
      return { score: 100, description: "No significant earthquake activity detected." };
    }
    const mag = data.features[0].properties.mag;
    const place = data.features[0].properties.place;
    let score = 0;
    let description = "";

    if (mag < 3) {
      score = 100; // Minor
      description = "Minor earthquake activity";
    } else if (mag >= 3 && mag < 5) {
      score = 70; // Moderate
      description = "Moderate earthquake activity";
    } else if (mag >= 5 && mag < 7) {
      score = 40; // Significant
      description = "Significant earthquake activity";
    } else {
      score = 0; // Major
      description = "Major earthquake activity";
    }

    return { score, description: `${description} near ${place} (Magnitude: ${mag})`, details: { magnitude: mag, place: place } };
  },
};

