{
  // SITUATION: What is the current state? What phase are we in, what's done, what's blocking? Scan history — never re-ask what's already known.
  situation: string,
  // TASK: 1-5 remaining steps. First item = what we're doing RIGHT NOW. Must advance toward completion.
  task: string[],
  // ACTION: Tools to execute the first task step. Use multiple for independent ops (e.g. read 3 files). Use single when steps depend on each other.
  actions: [
    {
      // Use this tool to READ the contents of a file. This is the ONLY way to see what's inside a file.
      tool_name: "read_file",
      // Absolute or relative path to the file
      path: string,
      // Optional: line number to start reading from (0-indexed)
      offset: int or null,
      // Optional: maximum number of lines to read (default 1000)
      limit: int or null,
    } or {
      // Use this tool to CREATE a new file or completely overwrite an existing one.
      tool_name: "write_file",
      // Absolute or relative path to the file
      path: string,
      // Full content of the file
      content: string,
    } or {
      // Use this tool to make precise edits to an existing file by replacing a specific string.
      tool_name: "edit_file",
      // Absolute or relative path to the file
      path: string,
      // The exact string to replace (must match exactly, including indentation)
      old_string: string,
      // The new string to replace it with
      new_string: string,
    } or {
      // Use this tool to run a shell command. CWD persists between calls. Always returns output — use exit code to decide next step.
      tool_name: "bash",
      // Shell command to execute
      command: string,
      // Short description of what this command does (for audit trail)
      description: string or null,
      // Timeout in milliseconds (default 120000 = 2 min, max 600000 = 10 min)
      timeout: int or null,
    } or {
      // Use this tool to run a long-running command in a background tmux window.
      tool_name: "bash_bg",
      // Short name for the tmux window, e.g. 'dev-server', 'build', 'tests'
      name: string,
      // Long-running command to run in background tmux window
      command: string,
    } or {
      // Use this tool to search file contents across the codebase using ripgrep.
      tool_name: "search_code",
      // Text or regex to search in file contents across the codebase (uses ripgrep)
      query: string,
    } or {
      // Use this tool to check git status — branch, staged/unstaged/untracked files.
      tool_name: "git_status",
      // Empty tool - just call it to get git status
      dummy: string or null,
    } or {
      // Use this tool to show UNCOMMITTED CHANGES (diff), NOT file contents. To read a file, use read_file instead.
      tool_name: "git_diff",
      // Optional specific file to diff. If not provided, shows all changes
      path: string or null,
      // If true, shows staged changes
      cached: bool or null,
    } or {
      // Use this tool to stage files for commit.
      tool_name: "git_add",
      // Files to add to staging area
      paths: string[],
    } or {
      // Use this tool to create a git commit with staged changes.
      tool_name: "git_commit",
      // Commit message
      message: string,
    } or {
      // Use this tool to open a file in the user's editor (e.g. vim, code). Does NOT read the file.
      tool_name: "open_editor",
      // File to open in user's editor
      path: string,
      // Optional line number to jump to
      line: int or null,
    } or {
      // Use this tool to ask the user a question when you need clarification.
      tool_name: "ask_user",
      // Question or clarification needed from the user
      question: string,
    } or {
      // Use this tool when the task is complete.
      tool_name: "finish",
      // Summary of what was accomplished
      summary: string,
    } or {
      // Use this tool to call an MCP server tool.
      tool_name: "mcp_call",
      // MCP server name (e.g. 'playwright', 'codegraph')
      server: string,
      // Tool name on that server (e.g. 'browser_navigate', 'kb_search')
      tool: string,
      // Tool arguments as JSON string, e.g. '{"query": "search term", "limit": 10}'. Pass null if no arguments needed.
      arguments: string or null,
    } or {
      // Save or forget a learning in persistent typed memory (MEMORY.jsonl). Survives across sessions. Use for: confirmed patterns, key decisions, user preferences, debugging insights. Do NOT save: temporary task state, speculative conclusions, things already in project CLAUDE.md/AGENTS.md.
      tool_name: "memory",
      // save = add new entry, forget = remove entries matching section
      operation: "save" or "forget",
      // decision = architectural choice with reasoning, pattern = reusable approach, preference = user/project style, insight = debugging finding, debug = temporary debug note
      category: "decision" or "pattern" or "preference" or "insight" or "debug",
      // Topic grouping, e.g. 'Model Findings', 'Build System', 'User Preferences'
      section: string,
      // The actual learning, decision, or pattern
      content: string,
      // Why this was recorded — what triggered it. Null for forget operations.
      context: string or null,
      // confirmed = verified across multiple sessions, tentative = first observation
      confidence: "confirmed" or "tentative",
    } or {
      // Use this tool to generate a project map — files, languages, LOC stats, and key public symbols extracted via tree-sitter. Fast, runs locally.
