import { describe, it, expect } from "vitest";
import { calculateComfortScore } from "../comfort-index";
import { SubScore } from "../modules/types";

describe("calculateComfortScore", () => {
  // Test case 1: Normal calculation with all modules
  it("should calculate the comfort score correctly with all modules", () => {
    const subScores: { [key: string]: SubScore } = {
      air: { score: 80, description: "Good air" },
      temperature: { score: 70, description: "Mild temp" },
      wind: { score: 90, description: "Light wind" },
      uv: { score: 60, description: "Moderate UV" },
      sea: { score: 75, description: "Calm sea" },
      earthquake: { score: 100, description: "No quakes" },
      fire: { score: 95, description: "No fires" },
      pollen: { score: 50, description: "High pollen" },
      pressure: { score: 85, description: "Stable pressure" },
      geomagnetic: { score: 90, description: "Low activity" },
      daylight: { score: 70, description: "Good daylight" },
    };

    const weights = {
      air: 0.22,
      temperature: 0.18,
      wind: 0.12,
      uv: 0.08,
      sea: 0.12,
      earthquake: 0.08,
      fire: 0.05,
      pollen: 0.05,
      pressure: 0.05,
      geomagnetic: 0.03,
      daylight: 0.02,
    };

    const expectedScore = (
      (80 * 0.22) +
      (70 * 0.18) +
      (90 * 0.12) +
      (60 * 0.08) +
      (75 * 0.12) +
      (100 * 0.08) +
      (95 * 0.05) +
      (50 * 0.05) +
      (85 * 0.05) +
      (90 * 0.03) +
      (70 * 0.02)
    ) / (0.22 + 0.18 + 0.12 + 0.08 + 0.12 + 0.08 + 0.05 + 0.05 + 0.05 + 0.03 + 0.02);

    expect(calculateComfortScore(subScores, weights)).toBeCloseTo(parseFloat(expectedScore.toFixed(2)));
  });

  // Test case 2: Partial modules (some missing)
  it("should calculate the comfort score correctly with partial modules", () => {
    const subScores: { [key: string]: SubScore } = {
      air: { score: 80, description: "Good air" },
      temperature: { score: 70, description: "Mild temp" },
      wind: { score: 90, description: "Light wind" },
    };

    const weights = {
      air: 0.22,
      temperature: 0.18,
      wind: 0.12,
      uv: 0.08,
    };

    const expectedScore = ((80 * 0.22) + (70 * 0.18) + (90 * 0.12)) / (0.22 + 0.18 + 0.12);

    expect(calculateComfortScore(subScores, weights)).toBeCloseTo(parseFloat(expectedScore.toFixed(2)));
  });

  // Test case 3: Edge case - empty subScores
  it("should return 0 if subScores is empty", () => {
    const subScores: { [key: string]: SubScore } = {};
    const weights = {
      air: 0.22,
      temperature: 0.18,
    };
    expect(calculateComfortScore(subScores, weights)).toBe(0);
  });

  // Test case 3: Edge case - zero weights for all active modules
  it("should return 0 if all active module weights are zero", () => {
    const subScores: { [key: string]: SubScore } = {
      air: { score: 80, description: "Good air" },
      temperature: { score: 70, description: "Mild temp" },
    };
    const weights = {
      air: 0,
      temperature: 0,
    };
    expect(calculateComfortScore(subScores, weights)).toBe(0);
  });

  // Test case 4: Weight normalization (implicit in the function, but test with custom weights that sum to something other than 1)
  it("should correctly normalize weights if they don't sum to 1", () => {
    const subScores: { [key: string]: SubScore } = {
      air: { score: 100, description: "Perfect air" },
      temperature: { score: 0, description: "Terrible temp" },
    };

    const weights = {
      air: 1,
      temperature: 1,
    };

    // If weights are 1 and 1, total weight is 2. (100*1 + 0*1) / 2 = 50
    expect(calculateComfortScore(subScores, weights)).toBe(50);
  });

