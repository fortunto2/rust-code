import { DataModule, SubScore, ModuleData } from "./modules/types";

interface ComfortWeights {
  [key: string]: number;
}

const defaultWeights: ComfortWeights = {
  air: 0.22,
  temperature: 0.18,
  wind: 0.12,
  uv: 0.08,
  sea: 0.12,
  earthquake: 0.08,
  fire: 0.05,
  pollen: 0.05,
  pressure: 0.05,
  geomagnetic: 0.03,
  daylight: 0.02,
};

export function calculateComfortScore(
  subScores: { [key: string]: SubScore },
  weights: ComfortWeights = defaultWeights
): number {
  let totalScore = 0;
  let totalWeight = 0;

  for (const id in subScores) {
    if (subScores.hasOwnProperty(id) && weights.hasOwnProperty(id)) {
      totalScore += subScores[id].score * weights[id];
      totalWeight += weights[id];
    }
  }

  if (totalWeight === 0) {
    return 0; // Avoid division by zero if no active modules
  }

  return parseFloat(((totalScore / totalWeight)).toFixed(2));
}

// This will be an array of all registered DataModules, imported from the modules directory
import { airModule } from "./modules/air";
import { weatherModule } from "./modules/weather";
import { marineModule } from "./modules/marine";
import { uvModule } from "./modules/uv";
import { daylightModule } from "./modules/daylight";

export const dataModules: DataModule[] = [
  airModule,
  weatherModule,
  marineModule,
  uvModule,
  daylightModule,
  // Add other modules here as they are implemented
];

export function registerDataModule(module: DataModule) {
  dataModules.push(module);
}

export async function getCityComfortScore(
  lat: number,
  lon: number
): Promise<{ score: number; subScores: { [key: string]: SubScore } }> {
  const activeModules = dataModules.filter((m) => m.enabled);
  const subScores: { [key: string]: SubScore } = {};
  const moduleWeights: ComfortWeights = {};

  let totalConfiguredWeight = 0;
  activeModules.forEach(m => totalConfiguredWeight += m.weight);

  for (const module of activeModules) {
    try {
      const rawData = await module.fetch(lat, lon);
      subScores[module.id] = module.normalize(rawData);
      // Re-normalize weights based on active modules
      moduleWeights[module.id] = module.weight / totalConfiguredWeight;
    } catch (error) {
      console.error(`Error fetching or normalizing data for module ${module.id}:`, error);
      // If a module fails, we can assign a default score or skip it.
      // For now, let's assign a neutral score (50) and log the error.
      subScores[module.id] = { score: 50, description: `Data unavailable: ${error.message}` };
      moduleWeights[module.id] = module.weight / totalConfiguredWeight; // Still include its weight
    }
  }

  const comfortScore = calculateComfortScore(subScores, moduleWeights);

  return { score: comfortScore, subScores };
}

