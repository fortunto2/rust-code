      (70 * defaultWeights.daylight)
    ) / (Object.values(defaultWeights).reduce((sum, weight) => sum + weight, 0));

    expect(calculateComfortScore(subScores)).toBeCloseTo(parseFloat(expectedScore.toFixed(2)));
  });
});

