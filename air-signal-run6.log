import { WeatherModule } from "../modules/weather";
import { ModuleData, SubScore } from "../modules/types";

describe("WeatherModule", () => {
  it("should fetch weather data", async () => {
    const mockFetch = jest.fn().mockResolvedValue({
      current: {
        temperature_2m: 20,
        relative_humidity_2m: 60,
        apparent_temperature: 22,
        wind_speed_10m: 10,
      },
    });
    global.fetch = mockFetch;

    const data = await WeatherModule.fetch(0, 0);
    expect(mockFetch).toHaveBeenCalledWith(
      expect.stringContaining("https://api.open-meteo.com/v1/forecast")
    );
    expect(data).toEqual({
      current: {
        temperature_2m: 20,
        relative_humidity_2m: 60,
        apparent_temperature: 22,
        wind_speed_10m: 10,
      },
    });
  });

  it("should normalize weather data to a SubScore", () => {
    const rawData: ModuleData = {
      current: {
        temperature_2m: 20,
        relative_humidity_2m: 60,
        apparent_temperature: 22,
        wind_speed_10m: 10,
      },
    };
    const subScore = WeatherModule.normalize(rawData);
    expect(subScore.score).toBeCloseTo(80);
    expect(subScore.description).toBe("Comfortable weather (20°C, feels like 22°C)");
    expect(subScore.details).toEqual({
      temperature_2m: 20,
      relative_humidity_2m: 60,
      apparent_temperature: 22,
      wind_speed_10m: 10,
    });
  });

  it("should handle missing weather data during normalization", () => {
    const rawData: ModuleData = {};
    const subScore = WeatherModule.normalize(rawData);
    expect(subScore.score).toBe(0);
    expect(subScore.description).toBe("Weather data unavailable");
  });

  it("should return a lower score for uncomfortable temperatures", () => {
    const rawData: ModuleData = {
      current: {
        temperature_2m: 35,
        relative_humidity_2m: 60,
        apparent_temperature: 38,
        wind_speed_10m: 10,
      },
    };
    const subScore = WeatherModule.normalize(rawData);
    expect(subScore.score).toBeLessThan(80);
    expect(subScore.description).toContain("Hot weather");
  });

  it("should return a lower score for high wind speeds", () => {
    const rawData: ModuleData = {
      current: {
        temperature_2m: 20,
        relative_humidity_2m: 60,
        apparent_temperature: 22,
        wind_speed_10m: 30,
      },
    };
    const subScore = WeatherModule.normalize(rawData);
    expect(subScore.score).toBeLessThan(80);
    expect(subScore.description).toContain("Windy weather");
  });
});

