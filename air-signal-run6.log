import { DataModule, SubScore, ModuleData } from "../types";
import { fetchOpenMeteoAirQuality } from "../../apis/open-meteo";

export const airModule: DataModule = {
  id: "air",
  name: "Air Quality",
  icon: "wind", // Placeholder icon
  weight: 0.22,
  enabled: true,
  fetch: async (lat: number, lon: number): Promise<ModuleData> => {
    const data = await fetchOpenMeteoAirQuality(lat, lon);
    return data;
  },
  normalize: (raw: ModuleData): SubScore => {
    // Assuming raw.current.european_aqi is available from Open-Meteo
    const aqi = raw.current?.european_aqi;
    let score = 0;
    let description = "";

    if (aqi === undefined || aqi === null) {
      score = 50; // Neutral if data is missing
      description = "Air quality data unavailable";
    } else if (aqi <= 20) {
      score = 100; // Excellent
      description = "Excellent air quality";
    } else if (aqi <= 40) {
      score = 80; // Good
      description = "Good air quality";
    } else if (aqi <= 60) {
      score = 60; // Moderate
      description = "Moderate air quality";
    } else if (aqi <= 80) {
      score = 40; // Unhealthy for sensitive groups
      description = "Unhealthy for sensitive groups";
    } else if (aqi <= 100) {
      score = 20; // Unhealthy
      description = "Unhealthy air quality";
    } else {
      score = 0; // Hazardous
      description = "Hazardous air quality";
    }

    return { score, description, details: { aqi } };
  },
};

