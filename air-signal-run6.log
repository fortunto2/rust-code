"""
Test file for FireModule.
"""

import { fireModule } from "../modules/fire";
import { ModuleData, SubScore } from "../modules/types";

describe("FireModule", () => {
  it("should have the correct id and name", () => {
    expect(fireModule.id).toBe("fire");
    expect(fireModule.name).toBe("Active Fires");
  });

  it("should fetch fire data", async () => {
    // Mock the fetch call to the NASA FIRMS API
    global.fetch = jest.fn(() =>
      Promise.resolve({
        json: () =>
          Promise.resolve({
            // Mock data structure based on FIRMS API response
            data: [
              ["2023-10-27", "123.45", "-67.89", "80", "MODIS", "Aqua", "B"],
            ],
          }),
      }) as Promise<Response>
    );

    const data = await fireModule.fetch(0, 0);
    expect(data).toBeDefined();
    expect(data.data.length).toBeGreaterThan(0);
    expect(global.fetch).toHaveBeenCalledWith(
      expect.stringContaining("firms.modaps.eosdis.nasa.gov")
    );
  });

  it("should normalize fire data to a subscore (no fires)", () => {
    const rawData: ModuleData = { data: [] };
    const subScore = fireModule.normalize(rawData);
    expect(subScore.score).toBe(100);
    expect(subScore.description).toBe("No active fires detected.");
  });

  it("should normalize fire data to a subscore (low confidence fire)", () => {
    const rawData: ModuleData = {
      data: [
        ["2023-10-27", "123.45", "-67.89", "30", "MODIS", "Aqua", "B"],
      ],
    };
    const subScore = fireModule.normalize(rawData);
    expect(subScore.score).toBeGreaterThan(70);
    expect(subScore.description).toContain("Low confidence fire activity");
  });

  it("should normalize fire data to a subscore (high confidence fire)", () => {
    const rawData: ModuleData = {
      data: [
        ["2023-10-27", "123.45", "-67.89", "90", "MODIS", "Aqua", "B"],
      ],
    };
    const subScore = fireModule.normalize(rawData);
    expect(subScore.score).toBeLessThan(30);
    expect(subScore.description).toContain("High confidence fire activity");
  });

  it("should handle missing data gracefully", () => {
    const rawData: ModuleData = {};
    const subScore = fireModule.normalize(rawData);
    expect(subScore.score).toBe(50); // Neutral score for unavailable data
    expect(subScore.description).toBe("Active fire data unavailable");
  });
});

