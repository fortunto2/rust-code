import { AirModule } from "../modules/air";
import { ModuleData, SubScore } from "../modules/types";

describe("AirModule", () => {
  it("should fetch air quality data", async () => {
    const mockFetch = jest.fn().mockResolvedValue({
      hourly: {
        pm2_5: [10],
        pm10: [20],
        european_aqi: [30],
        us_aqi: [40],
      },
    });
    global.fetch = mockFetch;

    const data = await AirModule.fetch(0, 0);
    expect(mockFetch).toHaveBeenCalledWith(
      expect.stringContaining("https://air-quality-api.open-meteo.com/v1/air-quality")
    );
    expect(data).toEqual({
      hourly: {
        pm2_5: [10],
        pm10: [20],
        european_aqi: [30],
        us_aqi: [40],
      },
    });
  });

  it("should normalize air quality data to a SubScore", () => {
    const rawData: ModuleData = {
      hourly: {
        pm2_5: [10],
        pm10: [20],
        european_aqi: [30],
        us_aqi: [40],
      },
    };
    const subScore = AirModule.normalize(rawData);
    expect(subScore.score).toBeCloseTo(70);
    expect(subScore.description).toBe("Moderate air quality (AQI: 30)");
    expect(subScore.details).toEqual({
      pm2_5: 10,
      pm10: 20,
      european_aqi: 30,
      us_aqi: 40,
    });
  });

  it("should handle missing AQI data during normalization", () => {
    const rawData: ModuleData = {
      hourly: {
        pm2_5: [10],
        pm10: [20],
      },
    };
    const subScore = AirModule.normalize(rawData);
    expect(subScore.score).toBe(0);
    expect(subScore.description).toBe("Air quality data unavailable");
  });
});

