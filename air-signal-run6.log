import { DataModule, ModuleData, SubScore } from "./types";
import { fetchOpenMeteoMarine } from "../apis/open-meteo";

export const MarineModule: DataModule = {
  id: "marine",
  name: "Marine",
  icon: "🌊",
  enabled: true,
  weight: 0.1,

  async fetch(lat: number, lon: number): Promise<ModuleData> {
    return fetchOpenMeteoMarine(lat, lon);
  },

  normalize(raw: ModuleData): SubScore {
    const current = raw.current;
    if (!current) {
      return {
        score: 0,
        description: "Marine data unavailable",
      };
    }

    const waveHeight = current.wave_height;
    const wavePeriod = current.wave_period;
    const waterTemperature = current.water_temperature;

    let score = 0;
    let description = "";

    // Wave Height (ideal: < 0.5m)
    if (waveHeight < 0.5) {
      score += 40;
    } else if (waveHeight < 1.5) {
      score += 20;
    } else {
      score += 10;
    }

    // Water Temperature (ideal: 20-25°C)
    if (waterTemperature >= 20 && waterTemperature <= 25) {
      score += 40;
    } else if (waterTemperature > 15 && waterTemperature < 30) {
      score += 20;
    } else {
      score += 10;
    }

    // Normalize score to 0-100 scale
    score = Math.min(100, Math.max(0, score));

    description = `Wave Height: ${waveHeight}m, Water Temp: ${waterTemperature}°C.`;

    return {
      score,
      description,
      details: {
        waveHeight,
        wavePeriod,
        waterTemperature,
      },
    };
  },
};

