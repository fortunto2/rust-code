"""
Test file for EarthquakeModule.
"""

import { EarthquakeModule } from "../earthquake";
import { ModuleData, SubScore } from "../../types";

describe("EarthquakeModule", () => {
  let earthquakeModule: EarthquakeModule;

  beforeEach(() => {
    earthquakeModule = new EarthquakeModule();
  });

  it("should have the correct id and name", () => {
    expect(earthquakeModule.id).toBe("earthquake");
    expect(earthquakeModule.name).toBe("Earthquake Activity");
  });

  it("should fetch earthquake data", async () => {
    // Mock the fetch call to the USGS API
    global.fetch = jest.fn(() =>
      Promise.resolve({
        json: () =>
          Promise.resolve({
            features: [
              {
                properties: { mag: 2.5, place: "10km E of Ojai, CA" },
                geometry: { coordinates: [-119.1, 34.4] },
                id: "usgs123",
              },
            ],
          }),
      }) as Promise<Response>
    );

    const data = await earthquakeModule.fetch(34.0522, -118.2437);
    expect(data).toBeDefined();
    expect(data.features.length).toBeGreaterThan(0);
    expect(global.fetch).toHaveBeenCalledWith(
      expect.stringContaining("earthquake.usgs.gov")
    );
  });

  it("should normalize earthquake data to a subscore", () => {
    const rawData: ModuleData = {
      features: [
        { properties: { mag: 2.5 } }, // Minor earthquake, should be good score
        { properties: { mag: 5.0 } }, // Moderate earthquake, should be lower score
        { properties: { mag: 7.0 } }, // Major earthquake, should be very low score
      ],
    };

    const subScoreMinor = earthquakeModule.normalize({
      features: [{ properties: { mag: 2.5 } }],
    });
    expect(subScoreMinor.score).toBeGreaterThan(70);
    expect(subScoreMinor.description).toContain("Minor earthquake activity");

    const subScoreModerate = earthquakeModule.normalize({
      features: [{ properties: { mag: 5.0 } }],
    });
    expect(subScoreModerate.score).toBeLessThan(70);
    expect(subScoreModerate.score).toBeGreaterThan(30);
    expect(subScoreModerate.description).toContain("Moderate earthquake activity");

    const subScoreMajor = earthquakeModule.normalize({
      features: [{ properties: { mag: 7.0 } }],
    });
    expect(subScoreMajor.score).toBeLessThan(30);
    expect(subScoreMajor.description).toContain("Significant earthquake activity");

    const subScoreNoEarthquakes = earthquakeModule.normalize({ features: [] });
    expect(subScoreNoEarthquakes.score).toBe(100);
    expect(subScoreNoEarthquakes.description).toContain("No significant earthquake activity");
  });

  it("should handle no earthquake data gracefully", () => {
    const rawData: ModuleData = { features: [] };
    const subScore = earthquakeModule.normalize(rawData);
    expect(subScore.score).toBe(100);
    expect(subScore.description).toBe("No significant earthquake activity detected.");
  });
});

