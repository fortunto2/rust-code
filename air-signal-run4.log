import { calculateComfortScore, dataModules } from "../comfort-index";
import { DataModule, SubScore, ModuleData } from "../modules/types";

describe("calculateComfortScore", () => {
  const mockModules: DataModule[] = [];

  it("should calculate comfort score with enabled modules", async () => {
    const mockSubScores = {
      air: { score: 50, description: "Good air" },
      temperature: { score: 100, description: "Ideal temp" },
      wind: { score: 100, description: "Low wind" },
    };
    const score = calculateComfortScore(mockSubScores);
    expect(score).toBeCloseTo(81.82);
  });

  it("should calculate comfort score with custom weights", () => {
    const mockSubScores = {
      air: { score: 50, description: "Good air" },
      temperature: { score: 100, description: "Ideal temp" },
    };
    const customWeights = { air: 0.5, temperature: 0.5 };
    const score = calculateComfortScore(mockSubScores, customWeights);
    expect(score).toBeCloseTo(75);
  });

  it("should return 0 if no sub-scores are provided", () => {
    const score = calculateComfortScore({});
    expect(score).toBe(0);
  });

  it("should return 0 if sub-scores have no corresponding weights", () => {
    const mockSubScores = {
      unknown: { score: 50, description: "Unknown" },
    };
    const score = calculateComfortScore(mockSubScores);
    expect(score).toBe(0);
  });
});

