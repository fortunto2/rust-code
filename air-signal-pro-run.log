import { describe, it, expect } from "vitest";
import { calculateComfortIndex } from "../comfort-index";
import { SubScore } from "../../types";

describe("calculateComfortIndex", () => {
  it("should calculate the comfort score correctly with all modules", () => {
    const scores: Record<string, SubScore> = {
      air: { id: "air", value: 50, normalized: 80, weight: 0.22 },
      temperature: { id: "temperature", value: 22, normalized: 70, weight: 0.18 },
      wind: { id: "wind", value: 5, normalized: 90, weight: 0.12 },
      uv: { id: "uv", value: 3, normalized: 60, weight: 0.08 },
      sea: { id: "sea", value: 20, normalized: 75, weight: 0.12 },
      earthquake: { id: "earthquake", value: 0, normalized: 100, weight: 0.08 },
      fire: { id: "fire", value: 0, normalized: 95, weight: 0.05 },
      pollen: { id: "pollen", value: 100, normalized: 50, weight: 0.05 },
      pressure: { id: "pressure", value: 1013, normalized: 85, weight: 0.05 },
      geomagnetic: { id: "geomagnetic", value: 1, normalized: 90, weight: 0.03 },
      daylight: { id: "daylight", value: 12, normalized: 70, weight: 0.02 },
    };

    const expectedTotalWeight = 0.22 + 0.18 + 0.12 + 0.08 + 0.12 + 0.08 + 0.05 + 0.05 + 0.05 + 0.03 + 0.02; // 1.0
    const expectedScore = (
      (80 * 0.22) +
      (70 * 0.18) +
      (90 * 0.12) +
      (60 * 0.08) +
      (75 * 0.12) +
      (100 * 0.08) +
      (95 * 0.05) +
      (50 * 0.05) +
      (85 * 0.05) +
      (90 * 0.03) +
      (70 * 0.02)
    ) / expectedTotalWeight;

    const result = calculateComfortIndex(scores);
    expect(result.totalScore).toBeCloseTo(expectedScore);
    expect(result.subScores).toEqual(scores);
  });

  it("should calculate the comfort score correctly with partial modules", () => {
    const scores: Record<string, SubScore> = {
      air: { id: "air", value: 50, normalized: 80, weight: 0.22 },
      temperature: { id: "temperature", value: 22, normalized: 70, weight: 0.18 },
      wind: { id: "wind", value: 5, normalized: 90, weight: 0.12 },
    };

    const expectedTotalWeight = 0.22 + 0.18 + 0.12;
    const expectedScore = (
      (80 * 0.22) +
      (70 * 0.18) +
      (90 * 0.12)
    ) / expectedTotalWeight;

    const result = calculateComfortIndex(scores);
    expect(result.totalScore).toBeCloseTo(expectedScore);
  });

  it("should return 0 if scores is empty", () => {
    const scores: Record<string, SubScore> = {};
    const result = calculateComfortIndex(scores);
    expect(result.totalScore).toBe(0);
    expect(result.subScores).toEqual({});
  });

  it("should return 0 if all active module weights are zero", () => {
    const scores: Record<string, SubScore> = {
      air: { id: "air", value: 50, normalized: 80, weight: 0 },
      temperature: { id: "temperature", value: 22, normalized: 70, weight: 0 },
    };
    const result = calculateComfortIndex(scores);
    expect(result.totalScore).toBe(0);
  });

  it("should correctly normalize weights if they don't sum to 1", () => {
    const scores: Record<string, SubScore> = {
      air: { id: "air", value: 50, normalized: 100, weight: 1 },
      temperature: { id: "temperature", value: 22, normalized: 0, weight: 1 },
    };

    // If weights are 1 and 1, total weight is 2. (100*1 + 0*1) / 2 = 50
    const result = calculateComfortIndex(scores);
    expect(result.totalScore).toBe(50);
  });

  it("should ignore modules with weight 0", () => {
    const scores: Record<string, SubScore> = {
      air: { id: "air", value: 50, normalized: 100, weight: 1 },
      temperature: { id: "temperature", value: 22, normalized: 0, weight: 0 },
    };

    // Temperature has weight 0, so it should be ignored. Total weight is 1. (100*1) / 1 = 100
    const result = calculateComfortIndex(scores);
    expect(result.totalScore).toBe(100);
  });
});

