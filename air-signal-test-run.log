interface ComfortWeights {
  [key: string]: number;
}

const defaultWeights: ComfortWeights = {
  air: 0.22,
  temperature: 0.18,
  wind: 0.12,
  uv: 0.08,
  sea: 0.12,
  earthquake: 0.08,
  fire: 0.05,
  pollen: 0.05,
  pressure: 0.05,
