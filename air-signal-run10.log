import { DataModule, ModuleData, SubScore } from "./types";
import { fetchOpenMeteoWeather } from "../apis/open-meteo"; // UV index is part of weather API

export const UVModule: DataModule = {
  id: "uv",
  name: "UV Index",
  icon: "☀️", // Placeholder, consider a UV-specific icon
  enabled: true,
  weight: 0.08,

  async fetch(lat: number, lon: number): Promise<ModuleData> {
    // Open-Meteo weather API includes UV index in daily data
    const data = await fetchOpenMeteoWeather(lat, lon);
    return data;
  },

  normalize(raw: ModuleData): SubScore {
    const daily = raw.daily;
    if (!daily || !daily.uv_index_max || daily.uv_index_max.length === 0) {
      return {
        score: 0,
        description: "UV index data unavailable",
      };
    }

    const uvIndex = daily.uv_index_max[0]; // Get today's max UV index

    let score = 0;
    let description = "";

    // UV Index comfort scoring (lower UV is generally more comfortable for prolonged exposure)
    // 0-2: Low (100 score)
    // 3-5: Moderate (70 score)
    // 6-7: High (40 score)
    // 8-10: Very High (20 score)
    // 11+: Extreme (0 score)

    if (uvIndex >= 0 && uvIndex <= 2) {
      score = 100;
      description = "Low UV index";
    } else if (uvIndex >= 3 && uvIndex <= 5) {
      score = 70;
      description = "Moderate UV index";
    } else if (uvIndex >= 6 && uvIndex <= 7) {
      score = 40;
      description = "High UV index";
    } else if (uvIndex >= 8 && uvIndex <= 10) {
      score = 20;
      description = "Very High UV index";
    } else {
      score = 0;
      description = "Extreme UV index";
    }

    return {
      score,
      description: `${description} (UV Index: ${uvIndex})`,
      details: {
        uvIndex,
      },
    };
  },
};

