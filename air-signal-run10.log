import { DataModule, ModuleData, SubScore } from "./types";
import { fetchOpenMeteo } from "../apis/open-meteo";

interface OpenMeteoDaylightResponse {
  latitude: number;
  longitude: number;
  generationtime_ms: number;
  utc_offset_seconds: number;
  timezone: string;
  timezone_abbreviation: string;
  elevation: number;
  daily_units: {
    time: string;
    sunrise: string;
    sunset: string;
    daylight_duration: string;
    sunshine_duration: string;
  };
  daily: {
    time: string[];
    sunrise: string[];
    sunset: string[];
    daylight_duration: number[];
    sunshine_duration: number[];
  };
}

export const DaylightModule: DataModule = {
  id: "daylight",
  name: "Daylight",
  weight: 0.02,
  icon: "☀️", // Placeholder icon
  enabled: true,

  async fetch(lat: number, lon: number): Promise<ModuleData> {
    const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=sunrise,sunset,daylight_duration,sunshine_duration&timezone=auto`;
    const response = await web_fetch(url);
    const data: OpenMeteoDaylightResponse = JSON.parse(response.content);
    return data;
  },

  normalize(raw: ModuleData): SubScore {
    const data = raw as OpenMeteoDaylightResponse;
    const daylightDuration = data.daily.daylight_duration[0]; // Duration in seconds

    // Normalize daylight duration to a 0-100 score.
    // A longer daylight duration is generally better, but extremely long or short days
    // (e.g., polar regions) might need special handling. For now, we'll assume a linear scale.
    // Average daylight duration is around 12 hours (43200 seconds).
    // Let's define a comfortable range, e.g., 10-14 hours (36000-50400 seconds) as ideal.
    // Score will be lower for durations outside this range.

    const minComfortDuration = 10 * 3600; // 10 hours in seconds
    const maxComfortDuration = 14 * 3600; // 14 hours in seconds
    const maxPossibleDuration = 24 * 3600; // 24 hours in seconds

    let score: number;
    if (daylightDuration >= minComfortDuration && daylightDuration <= maxComfortDuration) {
      score = 100; // Ideal range
    } else if (daylightDuration < minComfortDuration) {
      // Score decreases as daylight duration gets shorter than minComfortDuration
      score = 100 * (daylightDuration / minComfortDuration);
    } else {
      // Score decreases as daylight duration gets longer than maxComfortDuration (less ideal)
      score = 100 * (1 - (daylightDuration - maxComfortDuration) / (maxPossibleDuration - maxComfortDuration));
    }

    score = Math.max(0, Math.min(100, score)); // Ensure score is between 0 and 100

    const description = `Daylight duration: ${(daylightDuration / 3600).toFixed(1)} hours.`;

    return {
      score: parseFloat(score.toFixed(2)),
      description,
      details: { daylightDuration },
    };
  },
};

