import { DataModule, ModuleData, SubScore } from "./types";
import { fetchOpenMeteoWeather } from "../apis/open-meteo";

export const WeatherModule: DataModule = {
  id: "weather",
  name: "Weather",
  icon: "☀️",
  enabled: true,
  weight: 0.3,

  async fetch(lat: number, lon: number): Promise<ModuleData> {
    return fetchOpenMeteoWeather(lat, lon);
  },

  normalize(raw: ModuleData): SubScore {
    const current = raw.current;
    if (!current) {
      return {
        score: 0,
        description: "Weather data unavailable",
      };
    }

    const temperature = current.temperature_2m;
    const apparentTemperature = current.apparent_temperature;
    const humidity = current.relative_humidity_2m;
    const windSpeed = current.wind_speed_10m;
    const weatherCode = current.weather_code;

    let score = 0;
    let description = "";

    // Temperature (ideal: 20-25°C)
    if (temperature >= 20 && temperature <= 25) {
      score += 30;
    } else if (temperature > 15 && temperature < 30) {
      score += 15;
    } else {
      score += 5;
    }

    // Apparent Temperature (feels like - ideal: 18-24°C)
    if (apparentTemperature >= 18 && apparentTemperature <= 24) {
      score += 30;
    } else if (apparentTemperature > 14 && apparentTemperature < 28) {
      score += 15;
    } else {
      score += 5;
    }

    // Humidity (ideal: 40-60%)
    if (humidity >= 40 && humidity <= 60) {
      score += 20;
    } else if (humidity > 30 && humidity < 70) {
      score += 10;
    } else {
      score += 5;
    }

    // Wind Speed (ideal: < 10 km/h)
    if (windSpeed < 10) {
      score += 20;
    } else if (windSpeed < 20) {
      score += 10;
    } else {
      score += 5;
    }

    // Normalize score to 0-100 scale (max possible score is 100)
    score = Math.min(100, Math.max(0, score));

    // Generate description based on weather code and key metrics
    description = `Temp: ${temperature}°C (feels ${apparentTemperature}°C), Humidity: ${humidity}%, Wind: ${windSpeed} km/h.`;

    return {
      score,
      description,
      details: {
        temperature,
        apparentTemperature,
        humidity,
        windSpeed,
        weatherCode,
      },
    };
  },
};

